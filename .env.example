# Synapse Configuration

# ==================================
# Memory Storage Configuration
# ==================================

# Database path (SQLite local file)
SQLITE_DB_PATH=./data/synapse_memory.db

# ==================================
# AI Configuration
# ==================================

# Ollama API
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:latest

# Alternative AI Providers (future support)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ==================================
# Memory System Configuration
# ==================================

# Short-term memory
SHORT_TERM_CAPACITY=20
SHORT_TERM_TTL=300000  # 5 minutes in ms

# Long-term memory
LONG_TERM_IMPORTANCE_THRESHOLD=0.7
LONG_TERM_CONSOLIDATION_THRESHOLD=2

# Episodic memory
EPISODIC_MAX_LENGTH=10
EPISODIC_AUTO_ARCHIVE=2000  # 2 seconds for testing

# Auto-save interval (ms)
MEMORY_AUTO_SAVE_INTERVAL=30000  # 30 seconds

# ==================================
# Logging Configuration
# ==================================

# Log levels: 'debug', 'info', 'warn', 'error'
LOG_LEVEL=info

# Log directory
LOG_DIR=./logs

# ==================================
# Application Configuration
# ==================================

# Environment: 'development', 'production', 'test'
NODE_ENV=development

# Default language
DEFAULT_LANGUAGE=tr

# Session configuration
SESSION_TIMEOUT=3600000  # 1 hour in ms
