{
  "name": "synapse",
  "version": "1.0.0",
  "description": "AI-powered assistant with intelligent memory system and natural language command execution",
  "keywords": [
    "ai",
    "assistant",
    "clean-architecture",
    "llm",
    "ollama",
    "openai",
    "anthropic",
    "typescript",
    "memory-system",
    "sqlite",
    "cli",
    "cross-platform",
    "nlp",
    "command-execution"
  ],
  "homepage": "https://github.com/ernakkc/Synapse#readme",
  "bugs": {
    "url": "https://github.com/ernakkc/Synapse/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ernakkc/Synapse.git"
  },
  "private": false,
  "license": "MIT",
  "author": {
    "name": "Eren Akkoc",
    "email": "ern.akkc@gmail.com",
    "url": "https://erenakkoc.com"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "------------------ RUNNING ------------------": "",
    "start": "tsx src/main.ts",
    "cli": "tsx src/interfaces/cli/index.ts",
    "------------------ BUILDING -----------------": "",
    "build": "tsc",
    "----------------- DEVELOPMENT ---------------": "",
    "dev": "tsx watch src/main.ts",
    "------------------ TESTING ------------------": "",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:config": "tsx config/config.ts",
    "test:logger": "tsx tests/logger.test.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.4",
    "ollama": "^0.6.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.2",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18",
    "winston": "^3.19.0"
  }
}
